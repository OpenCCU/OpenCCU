CONFIG_NR_DRAM_BANKS=8

CONFIG_CMD_NVME=y
CONFIG_CMD_PCI=y

CONFIG_USB_STORAGE=y
CONFIG_USB_FUNCTION_MASS_STORAGE=y
CONFIG_USB_EHCI_HCD=y
CONFIG_USB_EHCI_GENERIC=y
CONFIG_USB_OHCI_HCD=y
CONFIG_USB_XHCI_HCD=y
# USB DWC3 support: RPi5 USB3 ports are on the RP1 chip (connected via PCIe).
# Full USB boot from RP1/DWC3 requires RP1 MFD initialization which is not
# yet fully supported in U-Boot. These options are enabled for future use.
CONFIG_USB_DWC3=y
CONFIG_USB_DWC3_GENERIC=y
CONFIG_USB_XHCI_DWC3=y

CONFIG_MMC_SDHCI_BCMSTB=y
CONFIG_SERIAL_PRESENT=y

CONFIG_PCI=y
CONFIG_PCI_BRCMSTB=y
CONFIG_NVME=y
CONFIG_NVME_PCI=y
